{
  "name": "automation-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "generate:use-cases": "node scripts/use-case-pages.mjs",
    "marketing:post": "node scripts/posting-packet.mjs",
    "monitor:gmail:query": "node scripts/gmail-monitor-config.mjs",
    "build": "tsc -b && vite build",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "read-excel-file": "9.0.9",
    "typescript": "6.0.3",
    "vite": "8.0.12"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "vitest": "4.1.6"
  }
}
